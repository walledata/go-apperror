#!/bin/sh
#
# pre-push: run code-quality checks before pushing.
#
# Enabled by `make install-hooks` (sets git config core.hooksPath .githooks).
#
# Scope: lint + test. Formatting is NOT re-checked here because the
# pre-commit hook already auto-formats staged files — by the time
# anything reaches a push, the formatting layer is settled.
#
# vuln (govulncheck) is intentionally NOT in this hook's scope right now:
# fetching vuln.go.dev through this dev environment's proxy has been
# returning EOF repeatedly, blocking pushes for environmental reasons
# rather than code reasons. The full `make verify` (lint + vuln + test)
# still runs in GitHub Actions CI, so the security check still gates
# merges; this hook just doesn't fail your push when the proxy hiccups.
# To re-enable locally once the network is reliable, swap
# `make lint test` back to `make verify`.
#
# Standard escape hatch for any hook failure: git push --no-verify

set -e

echo "pre-push: running lint + test (vuln skipped — see comment)..."
make lint test
